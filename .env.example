# ─────────────────────────────────────────────────────────────────────────────
# SentimentScribe — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Model serving
MODEL_TYPE=sklearn                          # "sklearn" or "distilbert"
ARTIFACTS_DIR=experiments/artifacts        # Path to trained model artifacts

# MLflow
MLFLOW_TRACKING_URI=mlruns                  # local or remote URI
# MLFLOW_TRACKING_URI=http://localhost:5000

# API
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
API_URL=http://localhost:8000               # URL the Streamlit dashboard calls

# Hugging Face (optional — for downloading models from Hub)
# HF_TOKEN=hf_...
